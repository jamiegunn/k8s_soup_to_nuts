{
  "name": "promql",
  "displayName": "PromQL",
  "scopeName": "source.promql",
  "fileTypes": ["promql"],
  "patterns": [
    {
      "name": "keyword.operator.binary.arithmetic.promql",
      "match": "(\\+|-|\\*|/|%|\\^)"
    },
    {
      "name": "keyword.operator.binary.set.promql",
      "match": "\\b(and|or|unless)\\b"
    },
    {
      "name": "keyword.operator.aggregator.promql",
      "match": "\\b(sum|min|max|avg|stddev|stdvar|count_values|count|bottomk|topk|quantile)\\b"
    },
    {
      "name": "keyword.operator.keyword.selector.promql",
      "match": "\\b(by|without|offset|on|ignoring|group_left|group_right|bool)\\b"
    },
    {
      "name": "string.quoted.double.promql",
      "match": "\"(\\\\.|[^\\\\\"])*\""
    },
    {
      "name": "string.quoted.single.promql",
      "match": "'(\\\\.|[^\\\\'])*'"
    },
    {
      "name": "string.quoted.other.backticks.promql",
      "begin": "`",
      "end": "`"
    },
    {
      "name": "support.function.promql",
      "match": "\\b(abs|absent_over_time|absent|ceil|changes|clamp_(max|min)|clamp|day_of_(month|week|year)|days_in_month|delta|deriv|exp|floor|histogram_(avg|count|sum|fraction|quantile|stddev|stdvar)|holt_winters|double_exponential_smoothing|hour|idelta|increase|irate|label_(join|replace)|ln|log(2|10)|minute|month|predict_linear|rate|resets|round|scalar|sgn|sort_by_label_desc|sort_by_label|sort_desc|sort|sqrt|timestamp|time|vector|year|(avg|min|max|sum|count|quantile|stddev|stdvar|last|present|mad)_over_time)(?=\\s*\\()"
    },
    {
      "name": "constant.numeric.promql",
      "match": "\\b[-+]?[0-9]*\\.?[0-9]+([eE][-+]?[0-9]+)?\\b"
    },
    {
      "name": "constant.numeric.range.promql",
      "match": "\\[[1-9][0-9]*(ms|s|m|h|d|w|y)(:[1-9][0-9]*(ms|s|m|h|d|w|y))?\\]"
    },
    {
      "name": "constant.numeric.offset.promql",
      "match": "[1-9][0-9]*(ms|s|m|h|d|w|y)"
    },
    {
      "name": "variable.parameter.label.promql",
      "match": "[_a-zA-Z][_a-zA-Z0-9]*"
    },
    {
      "name": "punctuation.parentheses.begin.promql",
      "match": "\\("
    },
    {
      "name": "punctuation.parentheses.end.promql",
      "match": "\\)"
    },
    {
      "name": "keyword.operator.compare.promql",
      "match": "(==|!=|=~|!~|<=|>=|<|>|=)"
    },
    {
      "name": "punctuation.separator.promql",
      "match": ","
    },
    {
      "name": "punctuation.braces.begin.promql",
      "match": "\\{"
    },
    {
      "name": "punctuation.braces.end.promql",
      "match": "\\}"
    },
    {
      "name": "comment.line.number-sign.promql",
      "match": "#.*"
    }
  ]
}
